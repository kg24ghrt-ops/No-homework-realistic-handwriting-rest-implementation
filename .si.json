{
  "plugin": "org.smartide.plugin.rust",
  "run": "cargo run",
  "intelligence": {
    ".json": {
      "enabled": true,
      "run": "vscode-json-language-server --stdio"
    },
    ".rs": {
      "enabled": false,
      "run": "rust-analyzer"
    },
    ".toml": {
      "enabled": true,
      "run": "taplo lsp stdio"
    },
    ".xml": {
      "enabled": true,
      "run": "lemminx"
    },
    ".yml": {
      "enabled": true,
      "run": "yaml-language-server --stdio"
    },
    ".md": {
      "enabled": false,
      "run": "marksman server"
    }
  }
}